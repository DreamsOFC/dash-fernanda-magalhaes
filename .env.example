# Exemplo de variáveis de ambiente para rodar a coleta LOCALMENTE.
# Copie para ".env" e preencha. O ".env" está no .gitignore e NUNCA é commitado.
# Em produção esses valores vivem em GitHub Secrets, não neste arquivo.

# Token do Meta (System User token, escopo ads_read, sem expiração)
META_ACCESS_TOKEN=

# Conta de anúncios (com o prefixo act_)
META_AD_ACCOUNT_ID=act_161375005284674

# Senha que a cliente digita para abrir o dashboard (protege os JSONs)
DASH_PASSWORD=

# Opcional: fixar uma versão específica da Graph API (padrão: v23.0)
# GRAPH_VERSION=v23.0
